OPENAI_MODEL=gpt-4o-2024-08-06

QUEUE_URL=http://localhost:8000
REDIS_HOST=redis
REDIS_PORT=6379
QUEUE_NAME=training_queue

K8S_NAMESPACE=default
KUBECONFIG=/Users/your-user/.kube/config

MAX_RETRIES=3
POLL_INTERVAL=5

GITHUB_TOKEN=ghp_your_github_token_here
HF_TOKEN=hf_your_huggingface_token_here
REPO_MOUNT_PATH=/repo
REPO_PATH_ENV_VAR=REPO_PATH

LOG_LEVEL=DEBUG